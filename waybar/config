{
    "layer": "bot",
    "spacing": 0,
    "height": 0,
    "margin": 5,
    "position": "bottom",

    "modules-left": ["sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": ["battery","pulseaudio" , "network",  "bluetooth" , "tray", "sway/language", "clock"],

    "sway/workspaces": {
        "all-outputs": false,
        "tooltip": false
    },

    "battery": {
        "interval": 5,
        "format": "{icon} {capacity}",
        "format-icons": ["", "", "", "", ""]
    },

    "network": {
        "format-disconnected": "󰅛",
        "format": "",
        "interval": 5,
        "tooltip": false
    },

    "bluetooth": {
        "interval": 5,
        "format": "󰂯",
        "format-disconnected":"󰂲",
        "tooltip": false
    },

    "sway/language": {
        "format": "{}",
        "tooltip": true
    },

    "tray": {
        "spacing": 5
    }
}